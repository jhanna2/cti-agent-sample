### Core
# Ollama default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

### Internal context sources (examples)
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_CMDB_INDEX=cmdb-assets

SQL_URL=sqlite:///./examples/top_actors.db
SQL_TOP_ACTORS_QUERY=SELECT name, priority FROM top_actors ORDER BY priority ASC LIMIT 20;

### Free CTI APIs (optional)
OTX_API_KEY=
URLSCAN_API_KEY=

# Example base URLs for free feeds (override if needed)
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CISA_ICS_ADVISORIES_URL=https://www.cisa.gov/sites/default/files/feeds/ics-advisories.xml
THREATFOX_API_URL=https://threatfox-api.abuse.ch/api/v1/
MALWAREBAZAAR_API_URL=https://mb-api.abuse.ch/api/v1/
URLHAUS_API_URL=https://urlhaus-api.abuse.ch/v1/
OTX_BASE_URL=https://otx.alienvault.com/api/v1/
URLSCAN_BASE_URL=https://urlscan.io/api/

# abuse.ch endpoints are typically public; keys not always required.
THREATFOX_API_KEY=
MALWAREBAZAAR_API_KEY=
URLHAUS_API_KEY=

### Paid CTI APIs (optional placeholders)
